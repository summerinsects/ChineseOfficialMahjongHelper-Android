<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="SpUsage,HardcodedText"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="vertical"
        android:background="#fff"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <include layout="@layout/dialog_header" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp10"
            android:layout_marginTop="@dimen/dp10"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp14"
            android:text="说明：\n1. 点对点传输须要两台设备连接同一WiFi或者两台设备之间通过热点连接，热点连接不耗费手机流量\n2. 传输前请确认是否开启了网络权限" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp35"
            android:layout_marginVertical="@dimen/dp20">
            <Button
                android:id="@+id/rtl_btn_send"
                android:layout_width="@dimen/dp80"
                android:layout_height="@dimen/dp30"
                android:background="@drawable/btn_square"
                android:textColor="#fff"
                android:textSize="@dimen/dp16"
                android:text="发送" />
            <Button
                android:id="@+id/rtl_btn_recv"
                android:layout_width="@dimen/dp80"
                android:layout_height="@dimen/dp30"
                android:layout_alignParentEnd="true"
                android:background="@drawable/btn_square"
                android:textColor="#fff"
                android:textSize="@dimen/dp16"
                android:text="接收" />
        </RelativeLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
