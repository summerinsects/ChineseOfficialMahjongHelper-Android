<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:ignore="SpUsage,PxUsage"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <CheckBox
        android:id="@+id/mfb_cb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/btn_square_toggle"
        android:button="@null" />
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/mfb_txt"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="@dimen/dp2"
        android:textColor="@color/text_3"
        android:gravity="center"
        app:autoSizeTextType="uniform"
        app:autoSizeMinTextSize="@dimen/dp6"
        app:autoSizeMaxTextSize="@dimen/dp16"
        app:autoSizeStepGranularity="2px" />
</RelativeLayout>
