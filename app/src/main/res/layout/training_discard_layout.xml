<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="SpUsage,HardcodedText,ContentDescription"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include layout="@layout/action_bar" />

    <TextView
        android:id="@+id/tdl_txt_inst"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dp5"
        android:padding="@dimen/dp10"
        android:background="@drawable/square_empty"
        android:backgroundTint="@color/theme_light"
        android:textColor="@color/text_3"
        android:textSize="@dimen/dp12"
        android:text="@string/dt_instruction" />

    <RelativeLayout
        android:id="@+id/tdl_rl_hand"
        android:layout_width="0dp"
        android:layout_height="0dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp5">

        <Button
            android:id="@+id/tdl_btn_skip"
            android:layout_width="@dimen/dp75"
            android:layout_height="@dimen/dp28"
            android:background="@drawable/btn_square"
            android:textColor="#fff"
            android:textSize="@dimen/dp16"
            android:text="跳过此题" />

        <Button
            android:id="@+id/tdl_btn_view"
            android:layout_width="@dimen/dp75"
            android:layout_height="@dimen/dp28"
            android:layout_below="@+id/tdl_btn_skip"
            android:layout_marginTop="@dimen/dp5"
            android:background="@drawable/btn_square"
            android:textColor="#fff"
            android:textSize="@dimen/dp16"
            android:text="查看答案" />

        <ImageView
            android:id="@+id/tdl_img_ans0"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/dp5"
            android:layout_toEndOf="@+id/tdl_btn_view"
            android:layout_alignBottom="@+id/tdl_btn_view"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/tdl_img_ans1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_toEndOf="@+id/tdl_img_ans0"
            android:layout_alignBottom="@+id/tdl_img_ans0"
            android:visibility="gone" />

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp28"
            android:layout_alignParentEnd="true">
            <TextView
                android:id="@+id/tdl_txt_rate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:textColor="@color/text_3"
                android:textSize="@dimen/dp14"
                android:text="0.00%" />
            <TextView
                android:id="@+id/tdl_txt_rate_prefix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignBaseline="@+id/tdl_txt_rate"
                android:layout_toStartOf="@+id/tdl_txt_rate"
                android:textColor="@color/text_3"
                android:textSize="@dimen/dp14"
                android:text="正确率：" />
            <TextView
                android:id="@+id/tdl_txt_cnt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/dp10"
                android:layout_alignBaseline="@+id/tdl_txt_rate"
                android:layout_toStartOf="@+id/tdl_txt_rate_prefix"
                android:textColor="@color/text_3"
                android:textSize="@dimen/dp14"
                android:text="0/0" />
        </RelativeLayout>

        <CheckBox
            android:id="@+id/tdl_cb_auto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp25"
            android:layout_alignParentEnd="true"
            android:checked="true"
            android:textColor="@color/text_1"
            android:textSize="@dimen/dp16"
            android:text="正确后自动跳转" />

    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tdl_rv_res"
        android:layout_margin="@dimen/dp5"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical" />

</LinearLayout>
