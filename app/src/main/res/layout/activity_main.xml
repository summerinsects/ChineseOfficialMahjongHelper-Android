<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="SpUsage,PxUsage,ContentDescription,HardcodedText,ButtonStyle"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:id="@+id/am_rl"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageButton
            android:id="@+id/am_btn_ext"
            android:layout_width="@dimen/dp28"
            android:layout_height="@dimen/dp28"
            android:layout_margin="@dimen/dp5"
            android:stateListAnimator="@animator/button_scale_animator"
            android:background="@drawable/ic_menu"
            android:backgroundTint="@color/theme_main">
        </ImageButton>

        <net.tziakcha.chineseofficialmahjonghelper.widget.MarqueeNoticeView
            android:id="@+id/am_rv_marquee"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp25"
            android:layout_marginTop="@dimen/dp50"
            android:background="#7fa6a6a6" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/dp5"
            android:layout_centerVertical="true"
            tools:ignore="RtlSymmetry">

            <Button
                android:id="@+id/am_btn_calc"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginEnd="@dimen/dp5"
                android:background="@drawable/btn_square"
                android:textColor="#fff"
                android:textSize="@dimen/dp24"
                android:text="算番器"
                app:layout_constraintDimensionRatio="5:4"
                app:layout_constraintEnd_toStartOf="@+id/am_btn_record"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/am_btn_record"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginEnd="@dimen/dp5"
                android:background="@drawable/btn_square"
                android:textColor="#fff"
                android:textSize="@dimen/dp24"
                android:text="计分器"
                app:layout_constraintDimensionRatio="5:4"
                app:layout_constraintEnd_toStartOf="@+id/am_btn_rule"
                app:layout_constraintStart_toEndOf="@+id/am_btn_calc"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/am_btn_rule"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginEnd="@dimen/dp5"
                android:background="@drawable/btn_square"
                android:textColor="#fff"
                android:textSize="@dimen/dp24"
                android:text="规则"
                app:layout_constraintDimensionRatio="5:4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/am_btn_record"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/am_btn_theory"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/dp5"
                android:layout_marginEnd="@dimen/dp5"
                android:background="@drawable/btn_square"
                android:textColor="#fff"
                android:textSize="@dimen/dp24"
                android:text="牌理"
                app:layout_constraintDimensionRatio="5:4"
                app:layout_constraintEnd_toStartOf="@+id/am_btn_train"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/am_btn_calc" />

            <Button
                android:id="@+id/am_btn_train"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/dp5"
                android:layout_marginEnd="@dimen/dp5"
                android:background="@drawable/btn_square"
                android:textColor="#fff"
                android:textSize="@dimen/dp24"
                android:text="训练"
                app:layout_constraintDimensionRatio="5:4"
                app:layout_constraintEnd_toStartOf="@+id/am_btn_other"
                app:layout_constraintStart_toEndOf="@+id/am_btn_theory"
                app:layout_constraintTop_toBottomOf="@+id/am_btn_record" />

            <Button
                android:id="@+id/am_btn_other"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/dp5"
                android:layout_marginEnd="@dimen/dp5"
                android:background="@drawable/btn_square"
                android:textColor="#fff"
                android:textSize="@dimen/dp24"
                android:text="其他"
                app:layout_constraintDimensionRatio="5:4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/am_btn_train"
                app:layout_constraintTop_toBottomOf="@+id/am_btn_rule" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/am_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_margin="@dimen/dp5"
            android:textColor="@color/text_1"
            android:textSize="@dimen/dp12"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>

    <LinearLayout
        android:layout_gravity="start"
        android:clickable="true"
        android:focusable="true"
        android:background="#fff"
        android:layout_width="@dimen/dp150"
        android:layout_height="match_parent"
        android:baselineAligned="false"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="@dimen/dp150"
            android:layout_height="@dimen/dp150"
            android:baselineAligned="false"
            android:orientation="vertical">
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="@color/text_1"
                android:textSize="@dimen/dp16"
                android:text="国标小助手"/>
            <TextView
                android:id="@+id/am_txt_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="@color/text_3"
                android:textSize="@dimen/dp12" />
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2px"
            android:background="@color/gray_6" />

        <Button
            android:id="@+id/am_btn_setting"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp50"
            android:background="?android:attr/selectableItemBackground"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="设置" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2px"
            android:background="@color/gray_6" />

        <Button
            android:id="@+id/am_btn_changelog"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp50"
            android:background="?android:attr/selectableItemBackground"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="更新日志" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2px"
            android:background="@color/gray_6" />

        <Button
            android:id="@+id/am_btn_version"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp50"
            android:background="?android:attr/selectableItemBackground"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="版本检测" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2px"
            android:background="@color/gray_6" />

        <Button
            android:id="@+id/am_btn_exit"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp50"
            android:background="?android:attr/selectableItemBackground"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="退出"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="2px"
            android:background="@color/gray_6" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
