<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="SpUsage,HardcodedText"
    android:baselineAligned="false"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include layout="@layout/action_bar" />

    <RelativeLayout
        android:id="@+id/tcl_rl_hand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp5"
        android:baselineAligned="false"
        android:orientation="horizontal">
        <RadioButton
            android:id="@+id/tcl_rb_cl"
            android:layout_width="@dimen/dp75"
            android:layout_height="@dimen/dp28"
            android:clickable="false"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="点和" />

        <RadioButton
            android:id="@+id/tcl_rb_sd"
            android:layout_width="@dimen/dp75"
            android:layout_height="@dimen/dp28"
            android:clickable="false"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="自摸" />

        <CheckBox
            android:id="@+id/tcl_cb_lt"
            android:layout_width="@dimen/dp75"
            android:layout_height="@dimen/dp28"
            android:clickable="false"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="绝张" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp5"
        android:layout_marginHorizontal="@dimen/dp5"
        android:baselineAligned="false"
        android:orientation="horizontal">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp28"
            android:layout_marginEnd="@dimen/dp5"
            android:gravity="center_vertical"
            android:textColor="@color/text_1"
            android:textSize="@dimen/dp16"
            android:text="圈风" />
        <RadioButton
            android:id="@+id/tcl_rb_pwe"
            android:layout_width="@dimen/dp55"
            android:layout_height="@dimen/dp28"
            android:clickable="false"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="东" />

        <RadioButton
            android:id="@+id/tcl_rb_pws"
            android:layout_width="@dimen/dp55"
            android:layout_height="@dimen/dp28"
            android:clickable="false"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="南" />
        <RadioButton
            android:id="@+id/tcl_rb_pww"
            android:layout_width="@dimen/dp55"
            android:layout_height="@dimen/dp28"
            android:clickable="false"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="西" />
        <RadioButton
            android:id="@+id/tcl_rb_pwn"
            android:layout_width="@dimen/dp55"
            android:layout_height="@dimen/dp28"
            android:clickable="false"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="北" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp5"
        android:layout_marginHorizontal="@dimen/dp5"
        android:baselineAligned="false"
        android:orientation="horizontal">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp28"
            android:layout_marginEnd="@dimen/dp5"
            android:gravity="center_vertical"
            android:textColor="@color/text_1"
            android:textSize="@dimen/dp16"
            android:text="门风" />
        <RadioButton
            android:id="@+id/tcl_rb_swe"
            android:layout_width="@dimen/dp55"
            android:layout_height="@dimen/dp28"
            android:clickable="false"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="东" />

        <RadioButton
            android:id="@+id/tcl_rb_sws"
            android:layout_width="@dimen/dp55"
            android:layout_height="@dimen/dp28"
            android:clickable="false"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="南" />
        <RadioButton
            android:id="@+id/tcl_rb_sww"
            android:layout_width="@dimen/dp55"
            android:layout_height="@dimen/dp28"
            android:clickable="false"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="西" />
        <RadioButton
            android:id="@+id/tcl_rb_swn"
            android:layout_width="@dimen/dp55"
            android:layout_height="@dimen/dp28"
            android:clickable="false"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp16"
            android:text="北" />
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp5"
        android:layout_marginHorizontal="@dimen/dp5">
        <Button
            android:id="@+id/tcl_btn_skip"
            android:layout_width="@dimen/dp75"
            android:layout_height="@dimen/dp28"
            android:layout_centerVertical="true"
            android:background="@drawable/btn_square"
            android:textColor="#fff"
            android:textSize="@dimen/dp16"
            android:text="跳过此题" />
        <TextView
            android:id="@+id/tcl_txt_rate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp14"
            android:text="0.00%" />
        <TextView
            android:id="@+id/tcl_txt_rate_prefix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignBaseline="@+id/tcl_txt_rate"
            android:layout_toStartOf="@+id/tcl_txt_rate"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp14"
            android:text="正确率：" />
        <TextView
            android:id="@+id/tcl_txt_cnt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp10"
            android:layout_centerVertical="true"
            android:layout_alignBaseline="@+id/tcl_txt_rate"
            android:layout_toStartOf="@+id/tcl_txt_rate_prefix"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp14"
            android:text="0/0" />
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp5"
        android:layout_marginHorizontal="@dimen/dp5">
        <Button
            android:id="@+id/tcl_btn_view"
            android:layout_width="@dimen/dp75"
            android:layout_height="@dimen/dp28"
            android:layout_centerVertical="true"
            android:background="@drawable/btn_square"
            android:textColor="#fff"
            android:textSize="@dimen/dp16"
            android:text="查看答案" />

        <CheckBox
            android:id="@+id/tcl_cb_auto"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp28"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:checked="true"
            android:textColor="@color/text_1"
            android:textSize="@dimen/dp16"
            android:text="正确后自动跳转" />

    </RelativeLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp5"
        android:layout_marginHorizontal="@dimen/dp5"
        android:gravity="center_vertical"
        android:textColor="@color/text_3"
        android:textSize="@dimen/dp14"
        android:text="注：部分题目可能不足8番。再次点击相同番数即提交" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp5">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp5"
                android:baselineAligned="false"
                android:orientation="horizontal">
                <ToggleButton
                    android:id="@+id/tcl_tb_f1"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="1"
                    android:textOn="1" />
                <ToggleButton
                    android:id="@+id/tcl_tb_f2"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="2"
                    android:textOn="2" />
                <ToggleButton
                    android:id="@+id/tcl_tb_f3"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="3"
                    android:textOn="3" />
                <ToggleButton
                    android:id="@+id/tcl_tb_f4"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="4"
                    android:textOn="4" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp5"
                android:layout_marginStart="@dimen/dp5"
                android:baselineAligned="false"
                android:orientation="horizontal">
                <ToggleButton
                    android:id="@+id/tcl_tb_f5"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="5"
                    android:textOn="5" />
                <ToggleButton
                    android:id="@+id/tcl_tb_f6"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="6"
                    android:textOn="6" />
                <ToggleButton
                    android:id="@+id/tcl_tb_f7"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="7"
                    android:textOn="7" />
                <ToggleButton
                    android:id="@+id/tcl_tb_f8"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="8"
                    android:textOn="8" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp5"
                android:layout_marginStart="@dimen/dp5"
                android:baselineAligned="false"
                android:orientation="horizontal">
                <ToggleButton
                    android:id="@+id/tcl_tb_f9"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="9"
                    android:textOn="9" />
                <ToggleButton
                    android:id="@+id/tcl_tb_f10"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="10"
                    android:textOn="10" />
                <ToggleButton
                    android:id="@+id/tcl_tb_f11"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="11"
                    android:textOn="11" />
                <ToggleButton
                    android:id="@+id/tcl_tb_f12"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="12"
                    android:textOn="12" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp5"
                android:layout_marginStart="@dimen/dp5"
                android:baselineAligned="false"
                android:orientation="horizontal">
                <ToggleButton
                    android:id="@+id/tcl_tb_f13"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="13"
                    android:textOn="13" />
                <ToggleButton
                    android:id="@+id/tcl_tb_f14"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="14"
                    android:textOn="14" />
                <ToggleButton
                    android:id="@+id/tcl_tb_f15"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="15"
                    android:textOn="15" />
                <ToggleButton
                    android:id="@+id/tcl_tb_f16"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp35"
                    android:layout_marginEnd="@dimen/dp5"
                    android:layout_weight="1"
                    android:background="@drawable/btn_square_toggle"
                    android:textSize="@dimen/dp16"
                    android:textColor="@color/text_2"
                    android:textOff="16"
                    android:textOn="16" />
            </LinearLayout>
        </LinearLayout>
        <ScrollView
            android:id="@+id/tcl_sv_ans"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp155"
            android:background="@color/theme_light"
            android:visibility="gone"
            android:fillViewport="true"
            android:scrollbars="vertical" />
    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tcl_rv_res"
        android:layout_margin="@dimen/dp5"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical" />

</LinearLayout>
