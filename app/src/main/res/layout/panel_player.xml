<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:ignore="SpUsage,HardcodedText,PxUsage,ContentDescription,LabelFor">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/txt_name"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp28"
        android:layout_marginEnd="@dimen/dp5"
        android:gravity="center"
        android:textColor="#ff7f00"
        app:autoSizeMaxTextSize="@dimen/dp16"
        app:autoSizeMinTextSize="@dimen/dp6"
        app:autoSizeStepGranularity="2px"
        app:autoSizeTextType="uniform" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/txt_score"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp28"
        android:layout_marginEnd="@dimen/dp5"
        android:gravity="center"
        android:text="+0"
        android:textColor="@color/text_3"
        android:textSize="@dimen/dp16" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp5"
        android:layout_marginEnd="@dimen/dp5">

        <RadioButton
            android:id="@+id/rb_win"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp28"
            android:layout_centerInParent="true"
            android:text="和牌"
            android:textColor="@color/text_2"
            android:textSize="@dimen/dp16" />
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp5"
        android:layout_marginEnd="@dimen/dp5">

        <RadioButton
            android:id="@+id/rb_clm"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp28"
            android:layout_centerInParent="true"
            android:text="点炮"
            android:textColor="@color/text_2"
            android:textSize="@dimen/dp16" />
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp5"
        android:layout_marginEnd="@dimen/dp5">

        <ImageButton
            android:id="@+id/ib_pen"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp28"
            android:layout_centerInParent="true"
            android:background="@drawable/btn_square_empty" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp28"
                android:layout_marginEnd="@dimen/dp5"
                android:gravity="center"
                android:text="判罚"
                android:textColor="@color/text_2"
                android:textSize="@dimen/dp16" />

            <TextView
                android:id="@+id/txt_pen"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp28"
                android:gravity="center"
                android:text="+0"
                android:textColor="@color/text_3"
                android:textSize="@dimen/dp16" />
        </LinearLayout>
    </RelativeLayout>

</merge>