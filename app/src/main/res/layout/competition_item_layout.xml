<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:ignore="SpUsage,HardcodedText"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground">
    <LinearLayout
        android:id="@+id/cil_rl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="vertical">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/cil_txt_title"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp20"
            android:layout_marginTop="@dimen/dp5"
            android:layout_marginHorizontal="@dimen/dp5"
            android:textColor="@color/text_1"
            android:textSize="@dimen/dp14" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp5">

            <ImageView
                android:layout_width="@dimen/dp18"
                android:layout_height="@dimen/dp20"
                android:paddingVertical="@dimen/dp2"
                android:layout_marginStart="@dimen/dp5"
                android:src="@drawable/ic_calendar"
                app:tint="@color/text_3" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/cil_txt_time"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp20"
                android:layout_marginStart="@dimen/dp24"
                android:layout_marginEnd="@dimen/dp80"
                android:textColor="@color/text_3"
                android:textSize="@dimen/dp14" />

            <ImageView
                android:layout_width="@dimen/dp18"
                android:layout_height="@dimen/dp20"
                android:paddingVertical="@dimen/dp2"
                android:layout_marginTop="@dimen/dp20"
                android:layout_marginStart="@dimen/dp5"
                android:src="@drawable/ic_location"
                app:tint="@color/text_3" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/cil_txt_loc"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp20"
                android:layout_marginTop="@dimen/dp20"
                android:layout_marginStart="@dimen/dp24"
                android:layout_marginEnd="@dimen/dp80"
                android:textColor="@color/text_3"
                android:textSize="@dimen/dp14" />

            <Button
                android:id="@+id/cil_btn"
                android:layout_width="@dimen/dp70"
                android:layout_height="@dimen/dp25"
                android:layout_marginEnd="@dimen/dp5"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/btn_square"
                android:textColor="#fff"
                android:textSize="@dimen/dp14"
                android:text="查看详情" />
        </RelativeLayout>
    </LinearLayout>
</FrameLayout>
