<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="SpUsage,ContentDescription"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground">

    <LinearLayout
        android:id="@+id/rhi_ll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/dp5"
        android:baselineAligned="false"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/rhi_txt_title"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp20"
                android:layout_marginEnd="@dimen/dp30"
                android:textColor="@color/text_1"
                android:textSize="@dimen/dp14" />

            <TextView
                android:id="@+id/rhi_txt_time"
                android:layout_width="match_parent"
                android:layout_marginEnd="@dimen/dp30"
                android:layout_below="@+id/rhi_txt_title"
                android:layout_height="@dimen/dp20"
                android:textColor="@color/text_3"
                android:textSize="@dimen/dp14" />

            <ImageButton
                android:id="@+id/rhi_btn_del"
                android:layout_width="@dimen/dp25"
                android:layout_height="@dimen/dp25"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:stateListAnimator="@animator/button_scale_animator"
                android:background="@drawable/ic_delete"
                android:backgroundTint="@color/gray_6" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/rhi_txt_pl0"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp20"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:textColor="@color/text_3"
                android:textSize="@dimen/dp14" />
            <TextView
                android:id="@+id/rhi_txt_pl1"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp20"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:textColor="@color/text_3"
                android:textSize="@dimen/dp14" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/rhi_txt_pl2"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp20"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:textColor="@color/text_3"
                android:textSize="@dimen/dp14" />
            <TextView
                android:id="@+id/rhi_txt_pl3"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp20"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:textColor="@color/text_3"
                android:textSize="@dimen/dp14" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
