<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="SpUsage,LabelFor"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:baselineAligned="false"
        android:orientation="vertical"
        android:background="#fff"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <include layout="@layout/dialog_header" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp8"
            android:layout_marginTop="@dimen/dp8"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp12"
            android:text="@string/its_instruction" />
        <TextView
            android:id="@+id/itl_txt_xmp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp8"
            android:textColor="@color/text_3"
            android:textSize="@dimen/dp12" />

        <EditText
            android:id="@+id/itd_et_input"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp25"
            android:layout_margin="@dimen/dp8"
            android:paddingHorizontal="@dimen/dp5"
            android:background="@drawable/square_empty"
            android:inputType="text"
            android:importantForAutofill="no"
            android:imeOptions="actionDone"
            android:maxLength="50"
            android:singleLine="true"
            android:textColor="@color/text_1"
            android:textSize="@dimen/dp14" />

        <include layout="@layout/dialog_footer2" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
