        <item name="colorPrimary">@color/theme_main</item>
        <item name="colorPrimaryVariant">@color/theme_pressed</item>
        <item name="colorOnPrimary">#fff</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/theme_main</item>
        <item name="colorSecondaryVariant">@color/theme_pressed</item>
        <item name="colorOnSecondary">@color/text_1</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="android:colorControlActivated">@color/theme_main</item>
    </style>
</resources>
