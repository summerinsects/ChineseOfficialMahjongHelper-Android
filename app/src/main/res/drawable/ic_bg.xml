<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:width="44px" android:height="60px">
        <shape android:shape="rectangle">
            <stroke android:width="1px" android:color="#000" />
        </shape>
    </item>
    <item android:left="1px" android:right="1px" android:top="1px" android:bottom="1px">
        <shape android:shape="rectangle">
            <solid android:color="@color/theme_main" />
        </shape>
    </item>
</layer-list>
